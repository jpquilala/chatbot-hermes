# AI provider. Use either OpenAI or OpenRouter.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=gpt-4o-mini

# Supabase persistent knowledge base.
# Use SUPABASE_SERVICE_ROLE_KEY only on the server/Vercel env vars. Never expose it in client code.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
